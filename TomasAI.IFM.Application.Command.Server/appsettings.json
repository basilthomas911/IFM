{
  "AzureStorage": {
    "BackupFiles": [
      {
        "Name": "eventdb",
        "Container": "domaindata",
        "BackupType": "diff",
        "Source": "E:\\backup\\eventdb-diff.bak",
        "Destination": "eventdb-diff.bak"
      },
      {
        "Name": "eventdb",
        "Container": "domaindata",
        "BackupType": "full",
        "Source": "E:\\backup\\eventdb-full.bak",
        "Destination": "eventdb-full.bak"
      }
    ]
  },
  "ConnectionStrings": {
    "EventDbConnection": "Data Source=DEV-SERVER;Initial Catalog=eventdb;Integrated Security=True;MultipleActiveResultSets=True",
    "TradeDbConnection": "Data Source=DEV-SERVER;Initial Catalog=tradedb;Integrated Security=True;MultipleActiveResultSets=True",
    "FundDbConnection": "Data Source=DEV-SERVER;Initial Catalog=funddb;Integrated Security=True;MultipleActiveResultSets=True",
    "ReferenceDbConnection": "Data Source=DEV-SERVER;Initial Catalog=referencedb;Integrated Security=True;MultipleActiveResultSets=True",
    "OptionPricerDbConnection": "Data Source=DEV-SERVER;Initial Catalog=optionpricerdb;Integrated Security=True;MultipleActiveResultSets=True",
    "MarketDataDbConnection": "Data Source=DEV-SERVER;Initial Catalog=marketdatadb;Integrated Security=True;MultipleActiveResultSets=True"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "TomasAI.IFM.Application.Command.Server": "Debug",
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Server.Kestrel": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "DiagnosticTrace" },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\TomasAI\\IFMAppDir\\CommandServer\\Logs\\command-server_.log",
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 4194304,
          "retainedFileCountLimit": 5,
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "IFM-CommandServer"
    }
  },
  "AllowedHosts": "*"
}
