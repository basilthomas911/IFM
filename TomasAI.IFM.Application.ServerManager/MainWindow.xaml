<Window x:Class="TomasAI.IFM.ServerManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TomasAI.IFM.ServerManager"
        mc:Ignorable="d"
        Title="IFM Server Manager" Height="450" Width="800"  WindowStyle="ToolWindow"
        Visibility="{Binding ConsoleVisibility}" 
        WindowState="{Binding ConsoleWindowState}"        >
    <Grid>
        <DataGrid Name="ConsoleStatusDataGrid" ItemsSource="{Binding ConsoleStatus}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Status Log" Width="3000" Binding="{Binding LogEntry}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
