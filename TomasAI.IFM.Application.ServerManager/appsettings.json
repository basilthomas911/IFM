{
  "ServerManager": {
    "ServerNames": "Command, Event, Query,Telemetry",
    "Command": {
      "WorkingDirectory": "C:\\TomasAI\\IFMAppDir\\CommandServer",
      "ExeName": "TomasAI.IFM.Application.Command.Server.exe"
    },
    "Event": {
      "WorkingDirectory": "C:\\TomasAI\\IFMAppDir\\EventServer",
      "ExeName": "TomasAI.IFM.Application.Event.Server.exe"
    },
    "Query": {
      "WorkingDirectory": "C:\\TomasAI\\IFMAppDir\\QueryServer",
      "ExeName": "TomasAI.IFM.Application.Query.Server.exe"
    },
    "Telemetry": {
      "WorkingDirectory": "C:\\TomasAI\\IFMAppDir\\TelemetryServer",
      "ExeName": "TomasAI.IFM.Application.Telemetry.Server.exe"
    },
    "PredictiveModel": {
      "WorkingDirectory": "C:\\TomasAI\\IFMAppDir\\PredictiveModelServer",
      "ExeName": "TomasAI.IFM.Application.PredictiveModel.Server.exe"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "DiagnosticTrace" },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\TomasAI\\IFMAppDir\\ServerManager\\Logs\\server-manager_.log",
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 4194304,
          "retainedFileCountLimit": 5,
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "IFM-ServerManager"
    }
  }

}
